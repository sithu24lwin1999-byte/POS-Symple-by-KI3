{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the KI3 POS system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "maxLength": 200 },
        "role": { "type": "string", "enum": ["ADMIN", "OWNER", "EMPLOYEE"] },
        "shopId": { "type": "string", "maxLength": 100 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Shop": {
      "title": "Shop",
      "description": "A tenant shop on the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "ownerName": { "type": "string", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 50 },
        "plan": { "type": "string", "enum": ["30000 MMK", "50000 MMK"] },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "EXPIRED"] },
        "expiryDate": { "type": "string", "maxLength": 50 },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string", "maxLength": 128 }
      },
      "required": ["name", "ownerName", "phone", "plan", "status", "expiryDate", "createdAt", "ownerId"]
    },
    "Product": {
      "title": "Product",
      "description": "A product sold by a shop.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "maxLength": 200 },
        "sku": { "type": "string", "maxLength": 100 },
        "category": { "type": "string", "maxLength": 100 },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "image": { "type": "string", "maxLength": 1000 },
        "shopId": { "type": "string", "maxLength": 128 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "sku", "category", "price", "cost", "stock", "shopId", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed in a shop.",
      "type": "object",
      "properties": {
        "shopId": { "type": "string", "maxLength": 128 },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "PREPARING", "COMPLETED", "CANCELLED"] },
        "type": { "type": "string", "enum": ["ONLINE", "OFFLINE"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "total", "status", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "System users (Admins, Owners, Employees)"
    },
    "/shops/{shopId}": {
      "schema": { "$ref": "#/entities/Shop" },
      "description": "Tenant shops"
    },
    "/shops/{shopId}/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products belonging to a specific shop"
    },
    "/shops/{shopId}/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders belonging to a specific shop"
    }
  }
}
